<h2>Show container</h2>

<ul>

  <li>
    <strong>Name:</strong>
    <%= @container.name %>
  </li>

  <li>
    <strong>Location:</strong>
    <%= @container.location %>
  </li>

  <li>
    <strong>User:</strong>
    <%= @container.user_id %>
  </li>

</ul>

<%= link "Edit", to: container_path(@conn, :edit, @container) %>
<%= link "Back", to: container_path(@conn, :index) %>
